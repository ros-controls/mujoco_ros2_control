<mujoco model="site_velocity_robot">
  <compiler angle="radian"/>
  <option gravity="0 0 0" timestep="0.002"/>

  <worldbody>
    <body name="slider" pos="0 0 0">
      <inertial pos="0 0 0" mass="1.0" diaginertia="0.01 0.01 0.01"/>
      <joint name="slider_joint" type="slide" axis="1 0 0" range="-2 2" damping="0.2"/>
      <geom name="slider_geom" type="box" size="0.05 0.05 0.05" rgba="0.1 0.5 0.8 1"/>
      <site name="drive_site" pos="0 0 0" size="0.02"/>
    </body>
  </worldbody>

  <actuator>
    <velocity name="slider_joint" site="drive_site" ctrlrange="-1 1"/>
  </actuator>
</mujoco>
