<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="site_velocity_robot">
  <xacro:arg name="headless" default="true"/>

  <link name="world"/>

  <link name="slider">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
    </inertial>
    <visual>
      <geometry>
        <box size="0.1 0.1 0.1"/>
      </geometry>
      <material name="blue">
        <color rgba="0.1 0.5 0.8 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.1 0.1 0.1"/>
      </geometry>
    </collision>
  </link>

  <joint name="slider_joint" type="prismatic">
    <parent link="world"/>
    <child link="slider"/>
    <axis xyz="1 0 0"/>
    <limit lower="-2.0" upper="2.0" velocity="1.0" effort="100.0"/>
  </joint>

  <ros2_control name="MujocoSystem" type="system">
    <hardware>
      <plugin>mujoco_ros2_control/MujocoSystemInterface</plugin>
      <param name="mujoco_model">$(find mujoco_ros2_control_tests)/test_resources/scenes/site_velocity_scene.xml</param>
      <param name="sim_speed_factor">1.0</param>
      <param name="headless">$(arg headless)</param>
    </hardware>

    <joint name="slider_joint">
      <command_interface name="velocity"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
  </ros2_control>
</robot>
