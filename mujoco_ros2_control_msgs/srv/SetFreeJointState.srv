# Directly set the pose and velocity of a MuJoCo free-joint object, identified by
# the name of the body it drives. Intended for teleporting/resetting objects in
# the world (e.g. a manipulable prop), similar to Gazebo's set_entity_state.
#
# An unset orientation defaults to identity (w=1, per the Quaternion.msg default)
# and an unset twist defaults to all-zero, so the common "reset to a pose, at
# rest" case only needs to fill in `name` and `pose`.

# List of free-joint bodies to set, see FreeJointState.msg for per-entry fields.
FreeJointState[] free_joint_states

---

# True if `name` was found, is driven by a free joint, and the state was applied.
bool success

# Human-readable status / error description (e.g. unknown body, not a free joint).
string message
