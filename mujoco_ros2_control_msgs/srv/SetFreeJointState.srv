# Directly set the pose and velocity of one or more MuJoCo free-joint objects, each
# identified by the name of the body it drives. Useful for teleporting/resetting objects,
# similar to Gazebo's set_entity_state.
#
# Applied atomically: every entry is validated before anything is written, so a single invalid
# entry rejects the whole request with no data modified. Duplicate body names are applied in
# order, so the last one wins.

# List of free-joint bodies to set, see FreeJointState.msg for per-entry fields.
FreeJointState[] free_joints

---

# True if every entry's body was found, driven by a free joint, and the state was applied.
bool success

# Human-readable status / error description (e.g. unknown body, not a free joint).
# On failure, identifies which entry (index and body name) caused the rejection.
string message
